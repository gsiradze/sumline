{
  "name": "grid",
  "private": true,
  "version": "0.1.0",
  "description": "A daily 5×5 deduction puzzle — one per day, six guesses.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:puzzles && tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src scripts",
    "format": "prettier --write .",
    "build:puzzles": "tsx scripts/build-puzzles.ts"
  },
  "dependencies": {
    "phaser": "4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "22.19.17",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "3.2.4",
    "autoprefixer": "10.5.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "25.0.1",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "terser": "^5.28.1",
    "tsx": "4.21.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.1",
    "vitest": "3.2.4"
  }
}
